# Python Bytecode & Cache Files
# These are auto-generated when Python runs your code
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual Environments
# These folders contain your installed packages - never commit them!
venv/
env/
ENV/
.venv/
env.bak/
venv.bak/

# Database Files
# SQLite databases may contain sensitive data or test data
*.db
*.sqlite
*.sqlite3
app.db
app/app.db

# Environment Variables & Secrets
# These files contain API keys, passwords, and other secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.envrc
*.env
# Exception: We DO want to commit the example file
!.env.example

# IDE & Editor Files
# Each developer uses different editors - these cause merge conflicts
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Operating System Files
# OS-specific metadata files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# Logs
# Application logs can be huge and contain sensitive data
*.log
logs/
screenshots/
profile/
browser-state/
session_artifacts/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing Artifacts
# Auto-generated when running tests
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.cache

# Build & Distribution
# Auto-generated when packaging Python applications
build/
dist/
*.egg-info/
*.egg
.eggs/
*.manifest
*.spec

# Docker
# Local Docker overrides should not be shared
docker-compose.override.yml

# Jupyter Notebook
# Checkpoint files
.ipynb_checkpoints

# pyenv
# Python version file
.python-version

# Celery
# Task queue beat schedule
celerybeat-schedule
celerybeat.pid

# SageMath
*.sage.py

# Spyder
.spyderproject
.spyproject

# Rope
.ropeproject

# mkdocs
/site

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre
.pyre/

# pytype
.pytype/

# Playwright
# Browser automation artifacts
playwright/.auth/
test-results/
playwright-report/

# Terraform / cloud local state
.terraform/
*.tfstate
*.tfstate.*
terraform.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Local tooling / private workflow files
.claude/
backup_data/
tmp/
*.har

# Backup files
*.bak
*.backup
