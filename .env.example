# Core application
PROJECT_NAME=AI Job Agent
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/jobagent_db

# Security
SECRET_KEY=replace-with-a-random-secret-at-least-32-characters-long
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT_PER_MINUTE=60

# LLM providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# ATS matching selection
ATS_MATCHING_LLM_PROVIDER=gemini
ATS_MATCHING_LLM_MODEL=

# Email integration
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USERNAME=
EMAIL_IMAP_PASSWORD=

# Storage / AWS
AWS_S3_ENDPOINT=
AWS_S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Queue / caching
REDIS_URL=redis://localhost:6379/0

# Job providers
ADZUNA_API_KEY=
ADZUNA_APP_ID=
JOOBLE_API_KEY=
INDEED_PUBLISHER_ID=
JSEARCH_API_KEY=

# Optional monitoring / notifications
SENTRY_DSN=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Browser automation
VNC_PASSWORD=change-me-before-use
